# ========================================
# Ark Opus — Environment Variables
# ========================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control!

# --- Database ---
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Anthropic (Writer Agent — Claude Sonnet 4) ---
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# --- Z.AI / GLM-5 (Research Deep Thinking, Source Verification) ---
ZAI_API_KEY="your-zai-api-key-here"

# --- DeepSeek (Briefing V3, Psychology V3, Feedback V3, Research Intel V3) ---
DEEPSEEK_API_KEY="your-deepseek-api-key-here"

# --- Exa.ai (Neural Search / Source Discovery) ---
EXA_API_KEY="your-exa-api-key-here"

# --- DataForSEO (MCP Server — SERP, Keyword, Backlink, On-Page) ---
DATAFORSEO_LOGIN="your-dataforseo-login"
DATAFORSEO_PASSWORD="your-dataforseo-password"

# --- Admin (API Key Management) ---
# Used to authenticate POST /admin/api-keys requests via X-Admin-Secret header.
# Generate a strong value: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET="your-admin-secret-here"

# --- Optional: Debug Mode (enables verbose SSE events) ---
# ARK_DEBUG=true
